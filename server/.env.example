# Server environment variables (example)
# Copy to `server/.env` for local dev, or set these in your hosting provider (Render/Railway/etc.)

# MongoDB connection string (Atlas/local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# CORS: allowed frontend origins.
# You can provide ONE origin or a comma-separated list (recommended for Vercel Preview + Production).
# Example:
# CLIENT_URL=https://your-app.vercel.app,https://your-app-git-branch-yourteam.vercel.app
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional: Google Gemini API key (used by /api/ai). If missing, server falls back to default suggestions.
API_KEY=

# Server port (most hosts set this automatically)
PORT=5000
